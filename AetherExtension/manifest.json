{
    "manifest_version": 3,
    "name": "Aether Memory",
    "version": "1.0",
    "description": "Long term memory layer for LLMs.",
    "permissions": [
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "http://127.0.0.1:8000/*",
      "https://chatgpt.com/*",
      "https://gemini.google.com/*"
    ],
    "content_scripts": [
      {
        "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"],
        "js": ["content.js"]
      }
    ]
  }